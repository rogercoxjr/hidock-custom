{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/**/*",
    "src/**/*.tsx",
    "electron/preload/*.ts",
    "electron/preload/*.d.ts",
    "electron/main/types/*.ts"
  ],
  "exclude": [
    "electron/main/types/jensen.ts",
    "src/lib/electron-api/__tests__/contract-harness.ts",
    "src/lib/electron-api/__tests__/*.contract.test.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": ["@types/w3c-web-usb"],
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@pages/*": ["./src/pages/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@lib/*": ["./src/lib/*"],
      "@store/*": ["./src/store/*"],
      "@types/*": ["./src/types/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}
